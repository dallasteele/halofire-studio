# Serve catalog GLBs from this Next.js app's /public directory
# (not from Pascal's CDN editor.pascal.app, which doesn't have our
# halofire-catalog/glb/* files).
#
# Pascal's resolver uses `process.env.NEXT_PUBLIC_ASSETS_CDN_URL || 'https://editor.pascal.app'`
# so an empty string falls back to the default. We set this to a
# localhost origin at dev time; for production, override with the
# hostname where the studio is served.
NEXT_PUBLIC_ASSETS_CDN_URL=http://localhost:3002
