{
  "name": "halofire-studio-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "HaloFire Studio — Tauri 2 desktop shell (AutoSPRINK-class CAD with integrated Pascal + OpenSCAD + agent pipeline)",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:sidecar": "python python_sidecar/build.py",
    "fetch:openscad": "python python_sidecar/download_openscad.py",
    "build:all": "bun run fetch:openscad && bun run build:sidecar && bun run build",
    "test:sidecar": "python -m pytest python_sidecar/test_entry.py -v",
    "test:fetch-openscad": "python -m pytest python_sidecar/test_download_openscad.py -v"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2"
  }
}
