[Unit]
Description=Halopenclaw Gateway (Halofire Studio tool dispatcher)
Documentation=https://github.com/dallasteele/halofire-studio
After=network.target
Wants=network-online.target

[Service]
Type=exec
User=halofire
Group=halofire
WorkingDirectory=/opt/halofire/halofire-studio/services/halopenclaw-gateway
Environment="PATH=/opt/halofire/halofire-studio/services/halopenclaw-gateway/.venv/bin:/usr/bin:/bin"
EnvironmentFile=/opt/halofire/halofire-studio/services/halopenclaw-gateway/.env
ExecStart=/opt/halofire/halofire-studio/services/halopenclaw-gateway/.venv/bin/uvicorn \
    main:app \
    --host 127.0.0.1 \
    --port 18790 \
    --workers 2 \
    --log-level info
Restart=on-failure
RestartSec=5s
# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/halofire/halofire-studio/services/halopenclaw-gateway/jobs

[Install]
WantedBy=multi-user.target
