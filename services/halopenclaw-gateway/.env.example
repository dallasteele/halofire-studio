# Copy to .env and fill in before running in production.
# .env is gitignored.

# Anthropic API key OR leave empty to fall back to OAuth / Claude Code CLI.
# Used by pdf_pipeline/claude_vision.py (L4 semantic labeling).
ANTHROPIC_API_KEY=

# Optional: override Claude model (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# Optional: override Haiku model for short-form classification
CLAUDE_HAIKU_MODEL=claude-haiku-4-5

# Gateway port (default 18790)
HALOPENCLAW_PORT=18790

# CubiCasa5k model weights — absolute path once downloaded from upstream
CUBICASA_MODEL_PATH=/opt/halofire/models/model_best_val_loss_var.pkl

# Where to stash uploaded PDFs + intermediate job state
HALOPENCLAW_JOB_DIR=./jobs
