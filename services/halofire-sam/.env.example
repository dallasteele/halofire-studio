# halofire-sam sidecar config

# Preferred model. Options we try in order at startup:
#   facebook/sam2.1-hiera-large   (SAM 2.1, open weights)
#   facebook/sam2-hiera-large     (SAM 2.0 fallback)
#   facebook/sam-vit-huge         (original SAM, last-resort fallback)
MODEL_ID=facebook/sam2.1-hiera-large

# Set if the model repo requires auth (SAM is public, usually unneeded).
# HF_TOKEN=

# cuda | cpu | auto  (auto = cuda if available, else cpu)
DEVICE=auto

# Where weights + HF cache live (defaults to ./.cache inside this service).
WEIGHT_CACHE_DIR=.cache

# Bind
HOST=127.0.0.1
PORT=18081

# Audit log location (created if missing). Resolved relative to repo root.
AUDIT_LOG=data/sam_requests.jsonl

# Safety caps
MAX_IMAGE_PIXELS=33177600   # 5760x5760; reject oversized payloads
