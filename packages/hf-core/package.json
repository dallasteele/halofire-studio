{
  "name": "@halofire/core",
  "version": "0.0.0",
  "description": "HaloFire Studio core — SCAD annotation parser, catalog Part schema, scene translation helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./catalog/part": {
      "types": "./dist/catalog/part.d.ts",
      "import": "./dist/catalog/part.js",
      "default": "./dist/catalog/part.js"
    },
    "./scad/parse-params": {
      "types": "./dist/scad/parse-params.d.ts",
      "import": "./dist/scad/parse-params.js",
      "default": "./dist/scad/parse-params.js"
    },
    "./scene/spawn-from-design": {
      "types": "./dist/scene/spawn-from-design.d.ts",
      "import": "./dist/scene/spawn-from-design.js",
      "default": "./dist/scene/spawn-from-design.js"
    },
    "./scene/translate-slice": {
      "types": "./dist/scene/translate-slice.d.ts",
      "import": "./dist/scene/translate-slice.js",
      "default": "./dist/scene/translate-slice.js"
    },
    "./sheets/generate-default-set": {
      "types": "./dist/sheets/generate-default-set.d.ts",
      "import": "./dist/sheets/generate-default-set.js",
      "default": "./dist/sheets/generate-default-set.js"
    },
    "./sheets/riser-diagram": {
      "types": "./dist/sheets/riser-diagram.d.ts",
      "import": "./dist/sheets/riser-diagram.js",
      "default": "./dist/sheets/riser-diagram.js"
    },
    "./sheets/floor-plan-layout": {
      "types": "./dist/sheets/floor-plan-layout.d.ts",
      "import": "./dist/sheets/floor-plan-layout.js",
      "default": "./dist/sheets/floor-plan-layout.js"
    },
    "./sheets/layer-mapping": {
      "types": "./dist/sheets/layer-mapping.d.ts",
      "import": "./dist/sheets/layer-mapping.js",
      "default": "./dist/sheets/layer-mapping.js"
    },
    "./report/pdf-sheet-set": {
      "types": "./dist/report/pdf-sheet-set.d.ts",
      "import": "./dist/report/pdf-sheet-set.js",
      "default": "./dist/report/pdf-sheet-set.js"
    },
    "./drawing/auto-dim-pipe-runs": {
      "types": "./dist/drawing/auto-dim-pipe-runs.d.ts",
      "import": "./dist/drawing/auto-dim-pipe-runs.js",
      "default": "./dist/drawing/auto-dim-pipe-runs.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc --build --noCheck",
    "dev": "tsc --build --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "pdf-lib": "^1.17.1"
  },
  "peerDependencies": {
    "@pascal-app/core": "^0.5.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.53",
    "@pascal-app/core": "*",
    "@pascal/typescript-config": "*",
    "pdfjs-dist": "^5.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "5.9.3"
  }
}
